      "domain": "market",
      "format": "json",
      "license": "Government of India Open Data",
      "origin": "https://data.gov.in",
      "requires_env": ["DATA_GOV_IN_API_KEY"],
      "enabled": true,
      "notes": "Fetched live when API key present; otherwise skipped with reason"
