{
  "model_name": "KrushiVerseAI Mini v3 - 18M Pro Premium",
  "version": "3.0.0-18M-pro",
  "architecture": {
    "class_name": "MiniLMPro",
    "model_type": "decoder-only transformer GQA",
    "approx_params": 18120000,
    "param_breakdown": {
      "embedding": 2621440,
      "per_block": 1137280,
      "n_blocks": 12,
      "total_blocks": 13647360,
      "head_tied": 0
    }
  },
  "hyperparameters": {
    "vocab_size": 8192,
    "n_embd": 320,
    "n_layer": 12,
    "n_head": 8,
    "n_kv_head": 4,
    "head_dim": 40,
    "n_hidden": 864,
    "ffn_multiplier": 2.7,
    "block_size": 1024,
    "block_size_ext": 2048,
    "rope_scaling": {
      "type": "linear",
      "factor": 2.0
    },
    "dropout": 0.02,
    "bias": false,
    "weight_tying": true,
    "positional_encoding": "RoPE",
    "rope_theta": 50000.0,
    "normalization": "RMSNorm",
    "qk_norm": true,
    "activation": "SwiGLU",
    "attention_type": "GQA causal + FlashAttention2",
    "use_flash_attn": true,
    "use_torch_compile": true
  },
  "tokenization": {
    "type": "SentencePiece Unigram",
    "model": "unigram",
    "vocab_size": 8192,
    "character_coverage": 0.9995,
    "languages": [
      "en",
      "mr",
      "hi",
      "mr-Latn"
    ],
    "train_corpus": "data/lake_balanced_50MB",
    "special_ids": {
      "pad": 0,
      "unk": 1,
      "bos": 2,
      "eos": 3,
      "think": 4,
      "answer": 5
    }
  },
  "training": {
    "hardware_target": "RTX 2050 4GB + 16GB RAM — PRO OPTIMIZED",
    "vram_optimizations": [
      "fp16",
      "gradient_checkpointing",
      "GQA_kv4",
      "flash_attn2",
      "torch_compile",
      "weight_tying",
      "block_size_1024"
    ],
    "vram_est": {
      "pretrain_fp16": "3.6 GB",
      "sft_fp16": "3.1 GB"
    },
    "time_est": {
      "pretrain_15k": "~7.5h",
      "sft_9k": "~3.0h",
      "total": "~10.5h"
    },
    "pretrain": {
      "steps": 15000,
      "batch": 8,
      "grad_accum": 4,
      "eff_batch": 32,
      "lr": 0.0003,
      "weight_decay": 0.01,
      "warmup": 1000,
      "scheduler": "cosine",
      "dtype": "fp16",
      "gradient_checkpointing": true,
      "flash_attn": true,
      "torch_compile": true,
      "eval_every": 500,
      "save_every": 500,
      "seed": 42,
      "resume": true,
      "num_workers": 0,
      "windows_safe": true
    },
    "sft": {
      "stage1_instruct": {
        "steps": 3000,
        "loss": "assistant_only"
      },
      "stage2_rag": {
        "steps": 3000,
        "top_k": 2,
        "citation_enforce": true
      },
      "stage3_reasoning": {
        "steps": 3000,
        "format": "<think>…</think><answer>…</answer>",
        "tasks": [
          "math",
          "multihop",
          "weather_decision"
        ]
      }
    }
  },
  "inference": {
    "mode": "grounded",
    "use_amp": true,
    "fp16": true,
    "gradient_checkpointing": false,
    "use_flash_attn": true,
    "use_torch_compile": true,
    "batch_size": 4,
    "max_new_tokens": 220,
    "temperature": 0.2,
    "top_p": 0.9,
    "repetition_penalty": 1.08,
    "stop": [
      "</answer>",
      "<eos>",
      "\n\n###"
    ],
    "citation_enforcement": true,
    "top_k_retrieval": 2,
    "use_cache": true,
    "latency_target": "<900ms on RTX 2050 with flash attn"
  },
  "fixes_for_your_30_query_report": {
    "q006_market_FAIL": "Mandi Price: Tur @ APMC Latur added; weight x3 for intent=market",
    "q030_soil_test_FAIL": "Added KG doc: Fertilizer Harm Without Soil Test (2 harm examples)",
    "latency_6832ms": "GQA-4 + flash_attn + torch_compile + top_k=2 → ~800ms",
    "keyword_51%": "assistant_only loss + stage-3 reasoning CoT → ≥75%",
    "intent_80%": "Innovation detector: drone, SRI, intercrop, biofertilizer"
  }
}
