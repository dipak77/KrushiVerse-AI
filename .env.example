# KrushiVerse-AI environment (copy to .env and fill values)

# --- Advanced RAG ---
ENABLE_WEB_RAG=true
ENABLE_TOOL_RAG=true
ENABLE_DENSE_RAG=true
RAG_TOP_K=8
WEB_CACHE_TTL_SEC=300

# Embeddings: auto | hash | minilm | openai
EMBEDDING_BACKEND=auto
EMBEDDING_DIM=384
EMBEDDING_MODEL=all-MiniLM-L6-v2
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional neural embeddings (pip install sentence-transformers)
# EMBEDDING_BACKEND=minilm

# Optional OpenAI-compatible embeddings
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# XAI_API_KEY=
# XAI_BASE_URL=https://api.x.ai/v1

# --- Qdrant (optional; local dense index used if unset) ---
# QDRANT_HOST=127.0.0.1
# QDRANT_PORT=6333
# QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=krushiverse_agri_kb
# QDRANT_RECREATE=false

# --- data.gov.in / Agmarknet open data ---
# Free key: https://data.gov.in → API keys
DATA_GOV_IN_API_KEY=
DATA_GOV_IN_BASE_URL=https://api.data.gov.in
AGMARKNET_RESOURCE_ID=9ef84268-d588-465a-a308-a864a43d0070
ENABLE_LIVE_AGMARKNET=true
OPENDATA_CACHE_TTL_SEC=600

# Optional legacy / other
# OPENWEATHER_API_KEY=
# NEO4J_URI=
